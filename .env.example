# Model provider
OPENROUTER_API_KEY=sk-...

# Slack app credentials
# Basic Information > App Credentials > Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret
# OAuth & Permissions > Bot User OAuth Token (after installing the app)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Optional: LibSQL/Turso URL. Defaults to a local file (file:./mastra.db)
# DATABASE_URL=libsql://your-db.turso.io

# API key protecting all /api/* routes (generate one: openssl rand -hex 32)
MASTRA_API_KEY=change-me

# Notion internal integration (notion.so/profile/integrations)
NOTION_API_KEY=ntn_...
# ID of the video ideas database (32-char hex from the database URL)
NOTION_DATABASE_ID=...
